<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="Border.ContentPanel">
        <Setter Property="Background" Value="{DynamicResource PanelBase}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderMain}" />
        <Setter Property="BorderThickness" Value="1,0,0,1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="60,40,0,0" />
    </Style>

    <Style Selector="Border.FooterPanel">
        <Setter Property="Background" Value="{DynamicResource PanelDark}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderMain}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="Padding" Value="60,20" />
    </Style>

    <Style Selector="TextBlock.H1">
        <Setter Property="FontSize" Value="48" />
        <Setter Property="FontWeight" Value="Black" />
        <Setter Property="Foreground" Value="{DynamicResource AccentRed}" />
        <Setter Property="LetterSpacing" Value="15" />
    </Style>

    <Style Selector="TextBlock.H2">
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="#666666" />
        <Setter Property="Margin" Value="0,10" />
        <Setter Property="LetterSpacing" Value="2" />
    </Style>

    <Style Selector="TextBlock.BodyText">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="Foreground" Value="{DynamicResource TextMain}" />
        <Setter Property="LineHeight" Value="30" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="Button.MenuBtn">
        <Setter Property="Background" Value="#1A000000" />
        <Setter Property="Foreground" Value="#E0E0E0" />
        <Setter Property="BorderThickness" Value="0,0,0,2" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderMain}" />
        <Setter Property="Padding" Value="15,8" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Duration="0:0:0.2" Property="BorderBrush" />
                <BrushTransition Duration="0:0:0.2" Property="Background" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.MenuBtn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#33BC4749" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentRed}" />
        <Setter Property="TextBlock.Foreground" Value="White" />
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style Selector="Button.ActionBtn">
        <Setter Property="Background" Value="{DynamicResource AccentRed}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="20,10" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style Selector="Button.ActionBtn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentRedHover}" />
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style Selector="Button.GhostBtn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderMain}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="#666" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="20,10" />
    </Style>
    <Style Selector="Button.GhostBtn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource PanelBase}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentRed}" />
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource AccentRed}" />
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style Selector="Separator">
        <Setter Property="Background" Value="{DynamicResource BorderMain}" />
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="0,10" />
    </Style>

    <Style Selector="Separator.Vertical">
        <Setter Property="Background" Value="{DynamicResource BorderMain}" />
        <Setter Property="Width" Value="1" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Margin" Value="20,0" />
    </Style>

    <Style Selector="TextBlock.SystemText">
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontFamily" Value="JetBrains Mono, DejaVu Sans Mono, Monospace" />
        <Setter Property="LetterSpacing" Value="1" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Opacity" Value="0.8" />
    </Style>
    

    <Style Selector="Button.Primary">
        <Setter Property="Background" Value="#BC4749"/>
    </Style>
    <Style Selector="Button.Primary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#A23C3E"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style Selector="Button.Secondary">
        <Setter Property="Background" Value="#457B9D"/>
    </Style>
    
    <Style Selector="TextBox.TerminalInput:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="#457B9D"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="TextBox.TerminalInput">
        <Setter Property="Background" Value="#1A1A1A"/>
        <Setter Property="Foreground" Value="#DDD"/>
        <Setter Property="BorderBrush" Value="#333"/>
        <Setter Property="CaretBrush" Value="#457B9D"/> 
        <Setter Property="SelectionBrush" Value="#457B9D"/> 
        <Style Selector="^:focus">
            <Setter Property="Foreground" Value="White"/>
            <Style Selector="^ /template/ Border#PART_BorderElement">
                <Setter Property="Background" Value="#111"/> 
                <Setter Property="BorderBrush" Value="#457B9D"/> 
                <Setter Property="BorderThickness" Value="1"/>
            </Style>
        </Style>
            
        <Style Selector="^ /template/ TextBlock#PART_Watermark">
            <Setter Property="Foreground" Value="#555"/>
        </Style>
    </Style>

    <Style Selector="Button.TerminalButton">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style Selector="Button.Secondary">
        <Setter Property="Background" Value="#BC4749"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <Style Selector="Button.Link">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="Gray"/>
        <Setter Property="FontSize" Value="10"/>
    </Style>
    <Style Selector="Button.Link:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#BC4749"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    
    <Style Selector="Border.AgentCard">
        <Setter Property="Background" Value="#CC050505"/>
        <Setter Property="BorderBrush" Value="#444"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="15,10"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Border.AgentCard:pointerover">
        <Setter Property="BorderBrush" Value="#BC4749"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="RenderTransform" Value="scale(1.02)"/>
    </Style>

    <Style Selector="TextBlock.AgentName">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontFamily" Value="Courier New"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
    </Style>

    <Style Selector="TextBlock.StatusText">
        <Setter Property="Foreground" Value="#457B9D"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="LetterSpacing" Value="1"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Ellipse.StatusDot">
        <Style.Animations>
            <Animation Duration="0:0:2" IterationCount="Infinite">
                <KeyFrame KeyTime="0:0:0"><Setter Property="Opacity" Value="1"/></KeyFrame>
                <KeyFrame KeyTime="0:0:1"><Setter Property="Opacity" Value="0.2"/></KeyFrame>
                <KeyFrame KeyTime="0:0:2"><Setter Property="Opacity" Value="1"/></KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
</Styles>
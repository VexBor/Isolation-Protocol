<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush Color="#BC4749" x:Key="AccentRed" />
    <SolidColorBrush Color="#A23335" x:Key="AccentRedHover" />
    <SolidColorBrush Color="#AAAAAA" x:Key="TextMain" />
    <SolidColorBrush Color="#555555" x:Key="TextMuted" />

    <SolidColorBrush Color="#121212" x:Key="PanelBase" />
    <SolidColorBrush Color="#080808" x:Key="PanelDark" />
    <SolidColorBrush Color="#333333" x:Key="BorderMain" />

    <RadialGradientBrush Center="50%,50%" Radius="1.2" x:Key="GlobalBackground">
        <GradientStop Color="#0D0D0D" Offset="0" />
        <GradientStop Color="#050505" Offset="1" />
    </RadialGradientBrush>

</ResourceDictionary>
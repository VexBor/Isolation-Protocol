<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="Border.MapCell">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
    </Style>

    <Style Selector="Border.Wall">
        <Setter Property="Background" Value="#415A77" />
        <Setter Property="BorderBrush" Value="#444444" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.Floor">
        <Setter Property="Background" Value="#3A5A40" />
    </Style>

    <Style Selector="Border.Trap">
        <Setter Property="Background" Value="#330000" />
        <Setter Property="BorderBrush" Value="Red" />
    </Style>

    <Style Selector="Border.Sand">
        <Setter Property="Background" Value="#C2B280" />

    </Style>
    <Style Selector="Border.Water">
        <Setter Property="Background" Value="#1B4965" />
    </Style>
</Styles>

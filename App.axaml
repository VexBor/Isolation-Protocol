<Application
    RequestedThemeVariant="Default"
    x:Class="Isolation_Protocol.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:local="using:Isolation_Protocol"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Application.Styles>
        <StyleInclude Source="/Styles/Menu.axaml" />
    </Application.Styles>

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>
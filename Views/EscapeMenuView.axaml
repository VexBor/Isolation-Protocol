<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Isolation_Protocol.Views.EscapeMenuView"
    x:DataType="viewModels1:EscapeMenuViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels1="clr-namespace:Isolation_Protocol.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Panel Background="#AA000000">
        <Border
            Background="#1A1A1A"
            BorderBrush="#333333"
            BorderThickness="2"
            CornerRadius="8"
            HorizontalAlignment="Center"
            MinWidth="300"
            Padding="30"
            VerticalAlignment="Center">

            <StackPanel Spacing="15">
                <TextBlock
                    FontSize="24"
                    FontWeight="Bold"
                    Foreground="#BC4749"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,10"
                    Text="ПАУЗА" />

                <Button
                    Classes="MenuBtn"
                    Command="{Binding ResumeCommand}"
                    Content="ПРОДОВЖИТИ"
                    HorizontalAlignment="Center" />

                <Separator Background="#333333" Margin="0,5" />

                <Button
                    Classes="MenuBtn"
                    Command="{Binding $parent[Window].((viewModels1:MainWindowViewModel)DataContext).ExitToMenuCommand}"
                    Content="ВИЙТИ В МЕНЮ"
                    HorizontalAlignment="Center" />

                <Button
                    Background="#44BC4749"
                    Classes="MenuBtn"
                    Command="{Binding QuitGameCommand}"
                    Content="ВИЙТИ НА РОБОЧИЙ СТІЛ"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Panel>
</UserControl>

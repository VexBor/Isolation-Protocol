<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:services="clr-namespace:Isolation_Protocol.Services"
             xmlns:view="clr-namespace:Isolation_Protocol.View"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Isolation_Protocol.Views.AnvilView"
             x:DataType="view:AnvilViewModel">
<Border Classes="TerminalBorder" Width="650" Height="420">
        <Grid ColumnDefinitions="2.2*, 3*">
            
            <StackPanel Grid.Column="0" Background="#111">
                <TextBlock Text="{Binding HeaderText}" 
                           Classes="AegisHeader" 
                           Margin="15,15,15,10"/>
            
                <ListBox ItemsSource="{Binding RecipeDisplayNames}" 
                         SelectedIndex="{Binding SelectedIndex}"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Classes="TerminalText"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="12" Margin="20,15">
                
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Text="{Binding CurrentItemName}" 
                               FontSize="20" 
                               Classes="AegisHeader"
                               VerticalAlignment="Center"/>
                    
                    <Image Grid.Column="1" 
                           Source="{Binding CurrentItemImage}" 
                           Width="48" Height="48"
                           RenderOptions.BitmapInterpolationMode="None"/> </Grid>
            
                <TextBlock Text="{Binding Source={x:Static services:Localization.Instance}, Path=[Anvil_Desc_Label]}" 
                           Classes="TerminalText" Foreground="Gray" FontSize="10"/>
                <TextBlock Text="{Binding ItemDescription}" 
                           Classes="TerminalText" 
                           TextWrapping="Wrap"/>

                <TextBlock Text="{Binding Source={x:Static services:Localization.Instance}, Path=[Anvil_Materials_Label]}" 
                           Classes="TerminalText" Foreground="Gray" FontSize="10" Margin="0,5,0,0"/>
                
                <Border Background="#05FFFFFF" Padding="12" CornerRadius="2">
                    <TextBlock Text="{Binding RequirementsText}" 
                               Classes="TerminalText" 
                               TextWrapping="Wrap"
                               FontFamily="Courier New"/>
                </Border>
                <TextBlock Foreground="Brown" 
                           Padding="10"  
                           Text="{Binding ErrorMessage}" 
                           FontSize="16">
                </TextBlock>
                <Button Content="{Binding Source={x:Static services:Localization.Instance}, Path=[Anvil_Craft_Btn]}" 
                        Classes="TerminalButton"
                        Command="{Binding CraftCommand}"
                        HorizontalAlignment="Stretch" 
                        Margin="0,15,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

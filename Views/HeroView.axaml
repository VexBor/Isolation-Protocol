<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Isolation_Protocol.Views.HeroView"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid ColumnDefinitions="3*, *">
        <!--  Left  -->
        <UniformGrid
            Background="#23233A"
            Columns="4"
            Grid.Column="0"
            Rows="2">
            <Button
                Background="#2E2E48"
                Click="Select_Button"
                CornerRadius="20"
                HorizontalAlignment="Stretch"
                Margin="30"
                VerticalAlignment="Stretch"
                x:Name="EliraButton">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="30"
                        Foreground="#EAEAF0"
                        HorizontalAlignment="Center"
                        Text="Еліра" />
                    <Image Source="../Assets/Hero/Elira.png" />
                </StackPanel>
            </Button>
            <Button
                Background="#2E2E48"
                Click="Select_Button"
                CornerRadius="20"
                HorizontalAlignment="Stretch"
                Margin="30"
                VerticalAlignment="Stretch"
                x:Name="TorinButton">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="30"
                        Foreground="#EAEAF0"
                        HorizontalAlignment="Center"
                        Text="Торін" />
                    <Image Source="../Assets/Hero/Torin.png" />
                </StackPanel>
            </Button>
            <Button
                Background="#2E2E48"
                Click="Select_Button"
                CornerRadius="20"
                HorizontalAlignment="Stretch"
                Margin="30"
                VerticalAlignment="Stretch"
                x:Name="LuciusButton">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="30"
                        Foreground="#EAEAF0"
                        HorizontalAlignment="Center"
                        Text="Люціус" />
                    <Image Source="../Assets/Hero/Lucius.png" />
                </StackPanel>
            </Button>
            <Button
                Background="#2E2E48"
                Click="Select_Button"
                CornerRadius="20"
                HorizontalAlignment="Stretch"
                Margin="30"
                VerticalAlignment="Stretch"
                x:Name="AriaButton">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="30"
                        Foreground="#EAEAF0"
                        HorizontalAlignment="Center"
                        Text="Арія" />
                    <Image Source="../Assets/Hero/Aria.png" />
                </StackPanel>
            </Button>
            <Button
                Background="#2E2E48"
                Click="Select_Button"
                CornerRadius="20"
                HorizontalAlignment="Stretch"
                Margin="30"
                VerticalAlignment="Stretch"
                x:Name="GrimButton">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="30"
                        Foreground="#EAEAF0"
                        HorizontalAlignment="Center"
                        Text="Грим" />
                    <Image Source="../Assets/Hero/Grim.png" />
                </StackPanel>
            </Button>
            <Button
                Background="#2E2E48"
                Click="Select_Button"
                CornerRadius="20"
                HorizontalAlignment="Stretch"
                Margin="30"
                VerticalAlignment="Stretch"
                x:Name="LiraButton">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="30"
                        Foreground="#EAEAF0"
                        HorizontalAlignment="Center"
                        Text="Ліра" />
                    <Image Source="../Assets/Hero/Lira.png" />
                </StackPanel>
            </Button>
            <Button
                Background="#2E2E48"
                Click="Select_Button"
                CornerRadius="20"
                HorizontalAlignment="Stretch"
                Margin="30"
                VerticalAlignment="Stretch"
                x:Name="SelinButton">

                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="30"
                        Foreground="#EAEAF0"
                        HorizontalAlignment="Center"
                        Text="Селін" />
                    <Image Source="../Assets/Hero/Selin.png" />
                </StackPanel>
            </Button>
            <Button
                Background="#2E2E48"
                Click="Select_Button"
                CornerRadius="20"
                HorizontalAlignment="Stretch"
                Margin="30"
                VerticalAlignment="Stretch"
                x:Name="KaelButton">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="30"
                        Foreground="#EAEAF0"
                        HorizontalAlignment="Center"
                        Text="Каел" />
                    <Image Source="../Assets/Hero/Kael.png" />
                </StackPanel>
            </Button>
        </UniformGrid>

        <!--  Rigth  -->
        <Grid
            Background="#1F1F35"
            Grid.Column="1"
            RowDefinitions="Auto, *, Auto, Auto">

            <TextBlock
                FontSize="36"
                Foreground="#EAEAF0"
                Grid.Row="0"
                HorizontalAlignment="Center"
                Margin="0,30,0,0"
                Text="Оберіть героя"
                x:Name="heroNameText" />

            <Border
                Background="#7C5CFF"
                BorderBrush="#3F3F64"
                BorderThickness="10"
                CornerRadius="20"
                Grid.Row="1"
                Margin="15"
                MaxHeight="550"
                MaxWidth="350">
                <Image x:Name="selectedHeroImage" />
            </Border>
            <UniformGrid
                Columns="2"
                Grid.Row="2"
                HorizontalAlignment="Center"
                Margin="30,15"
                Rows="2">

                <TextBlock
                    FontSize="20"
                    Foreground="#EAEAF0"
                    Margin="15"
                    Text="HP: 0"
                    x:Name="heroHealthText" />
                <TextBlock
                    FontSize="20"
                    Foreground="#EAEAF0"
                    Margin="15"
                    Text="Stamina: 0"
                    x:Name="heroStaminaText" />
                <TextBlock
                    FontSize="20"
                    Foreground="#EAEAF0"
                    Margin="15"
                    Text="Armor: 0"
                    x:Name="heroArmorText" />
                <TextBlock
                    FontSize="20"
                    Foreground="#EAEAF0"
                    Margin="15"
                    Text="Str: 0"
                    x:Name="heroStrengthText" />

            </UniformGrid>
            <Button
                Background="#22C55E"
                CornerRadius="15"
                FontSize="50"
                Foreground="#EAEAF0"
                Grid.Row="3"
                HorizontalAlignment="Center"
                Margin="30,0,30,30">
                Start
            </Button>
        </Grid>
    </Grid>
</UserControl>

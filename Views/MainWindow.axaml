<Window
    CanResize="False"
    Title="Isolation_Protocol"
    WindowState="FullScreen"
    d:DesignHeight="1080"
    d:DesignWidth="1920"
    mc:Ignorable="d"
    x:Class="Isolation_Protocol.Views.MainWindow"
    x:DataType="vm:MainWindowViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:Isolation_Protocol.Views"
    xmlns:vm="using:Isolation_Protocol.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type vm:MenuViewModel}">
            <views:MainView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MapViewModel}">
            <views:MapView />
        </DataTemplate>
    </Window.DataTemplates>

    <ContentControl Content="{Binding CurrentPage}" />
</Window>
<Window
    CanResize="False"
    Icon="/Assets/avalonia-logo.ico"
    Title="Isolation_Protocol"
    WindowState="FullScreen"
    d:DesignHeight="1080"
    d:DesignWidth="1920"
    mc:Ignorable="d"
    x:Class="Isolation_Protocol.Views.MainWindow"
    x:DataType="vm:MainWindowViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:Isolation_Protocol.Views"
    xmlns:vm="using:Isolation_Protocol.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type vm:InventoryViewModel}">
            <views:InventoryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HeroViewModel}">
            <views:HeroView />
        </DataTemplate>
    </Window.DataTemplates>


    <Grid RowDefinitions="Auto, *">

        <!--  Top panel  -->
        <Grid
            Background="#181825"
            ColumnDefinitions="Auto, 270, Auto, *, Auto"
            Grid.Row="0"
            Height="135"
            VerticalAlignment="Top">

            <Button
                Background="#2E2E48"
                BorderThickness="0"
                Command="{Binding OpenSettingsCommand}"
                CornerRadius="20"
                Grid.Column="0"
                Height="100"
                Margin="15"
                Width="100">
                <Image Source="../Assets/settings.png" />
            </Button>

            <StackPanel
                Grid.Column="2"
                Orientation="Horizontal"
                VerticalAlignment="Center">

                <Button
                    Background="#2E2E48"
                    BorderThickness="0"
                    Command="{Binding OpenHeroMenuCommand}"
                    CornerRadius="20"
                    FontSize="40"
                    Height="100"
                    Margin="0,0,35,0"
                    Width="100">
                    <Image Source="../Assets/heroIcon.png" />
                </Button>
                <Button
                    Background="#2E2E48"
                    BorderThickness="0"
                    Command="{Binding OpenInventoryCommand}"
                    CornerRadius="20"
                    Height="100"
                    Margin="0,0,35,0"
                    Width="100" />
                <Button
                    Background="#2E2E48"
                    BorderThickness="0"
                    CornerRadius="20"
                    Height="100"
                    Margin="0,0,35,0"
                    Width="100">
                    <Image Source="../Assets/shop.png" />
                </Button>
                <Button
                    Background="#2E2E48"
                    BorderThickness="0"
                    CornerRadius="20"
                    Height="100"
                    Margin="0,0,35,0"
                    Width="100">
                    <Image Source="../Assets/info.png" />
                </Button>
                <Button
                    Background="#2E2E48"
                    BorderThickness="0"
                    CornerRadius="20"
                    Height="100"
                    Margin="0,0,35,0"
                    Width="100">
                    <Image Source="../Assets/question.png" />
                </Button>
            </StackPanel>

            <Border
                Background="#2E2E48"
                CornerRadius="20"
                Grid.Column="3"
                Margin="0,15,15,15">

                <TextBlock
                    FontSize="50"
                    HorizontalAlignment="Center"
                    Text="1221$"
                    VerticalAlignment="Center" />
            </Border>

            <Button
                Background="#2E2E48"
                BorderThickness="0"
                CornerRadius="20"
                Grid.Column="4"
                Height="100"
                Margin="0,15,15,15"
                Width="100">
                <Image Source="../Assets/leave.png" />
            </Button>
        </Grid>

        <!--  Base panel  -->
        <ContentControl Content="{Binding CurrentPage}" Grid.Row="1" />
    </Grid>
</Window>
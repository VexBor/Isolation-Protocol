<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Isolation_Protocol.Views.MapView"
    x:DataType="viewModels1:PlayerViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels1="clr-namespace:Isolation_Protocol.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.DataContext>
        <viewModels1:PlayerViewModel />
    </Design.DataContext>

    <Grid Background="#1a1a1a">
        <Canvas Background="#050505" Name="GameCanvas">

            <Border
                Background="#00ff41"
                Canvas.Left="{Binding X}"
                Canvas.Top="{Binding Y}"
                CornerRadius="4"
                Height="{Binding Height}"
                Width="{Binding Width}">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="10"
                        Color="#00ff41"
                        Opacity="0.5" />
                </Border.Effect>
            </Border>

        </Canvas>
    </Grid>
</UserControl>

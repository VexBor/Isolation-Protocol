<UserControl
    d:DesignHeight="4000"
    d:DesignWidth="4000"
    mc:Ignorable="d"
    x:Class="Isolation_Protocol.Views.MapView"
    x:DataType="viewModels1:MapViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels1="clr-namespace:Isolation_Protocol.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Design.DataContext>
        <viewModels1:MapViewModel />
    </Design.DataContext>


    <UserControl.Styles>
        <Style Selector="Border.MapCell">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
        </Style>

        <Style Selector="Border.Wall">
            <Setter Property="Background" Value="#415A77" />
            <Setter Property="BorderBrush" Value="#444444" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="Border.Floor">
            <Setter Property="Background" Value="#3A5A40" />
        </Style>

        <Style Selector="Border.Trap">
            <Setter Property="Background" Value="#330000" />
            <Setter Property="BorderBrush" Value="Red" />
        </Style>

        <Style Selector="Border.Sand">
            <Setter Property="Background" Value="#C2B280" />

        </Style>
        <Style Selector="Border.Water">
            <Setter Property="Background" Value="#1B4965" />
        </Style>
    </UserControl.Styles>
    <Grid Background="#1a1a1a">

        <ScrollViewer
            HorizontalScrollBarVisibility="Hidden"
            Name="MapScroll"
            Offset="{Binding ScrollPos}"
            VerticalScrollBarVisibility="Hidden">
            <Canvas
                Background="#050505"
                Height="4000"
                Name="GameCanvas"
                Width="4000">
                <!--  Гравець  -->
                <Border
                    Background="#00ff41"
                    Canvas.Left="{Binding Player.X}"
                    Canvas.Top="{Binding Player.Y}"
                    CornerRadius="4"
                    Height="{Binding Player.Height}"
                    Width="{Binding Player.Width}"
                    ZIndex="5">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="10"
                            Color="#00ff41"
                            Opacity="0.5" />
                    </Border.Effect>
                </Border>
            </Canvas>
        </ScrollViewer>

        <!--  Інший візуал  -->

        <Border
            BorderThickness="0,2,0,0"
            CornerRadius="8,8,0,0"
            Height="200"
            Margin="10,0,10,0"
            VerticalAlignment="Bottom">
            <Grid ColumnDefinitions="200, *, 300" Margin="10">

                <!--  Герой (Стати)  -->
                <Grid
                    Grid.Column="0"
                    Margin="0,0,10,0"
                    RowDefinitions="*, Auto, Auto, Auto">
                    <ProgressBar
                        Classes="HpBar"
                        Grid.Row="1"
                        Value="{Binding Player.Health}" />

                    <ProgressBar
                        Classes="HungerBar"
                        Grid.Row="2"
                        Value="{Binding Player.Hunger}" />

                    <ProgressBar
                        Classes="StaminaBar"
                        Grid.Row="3"
                        Value="{Binding Player.Stamina}" />
                </Grid>

                <!--  Інвентарь  -->
                <UniformGrid
                    Columns="3"
                    Grid.Column="2"
                    Margin="10,10,10,10"
                    Rows="2">

                    <Border Classes="Slot">
                        <TextBlock Text="1" />
                    </Border>

                    <Border Classes="Slot">
                        <TextBlock Text="2" />
                    </Border>

                    <Border Classes="Slot">
                        <TextBlock Text="3" />
                    </Border>

                    <Border Classes="Slot">
                        <TextBlock Text="4" />
                    </Border>

                    <Border Classes="Slot">
                        <TextBlock Text="5" />
                    </Border>

                    <Border Classes="Slot">
                        <TextBlock Text="6" />
                    </Border>
                </UniformGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>

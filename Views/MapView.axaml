<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="Isolation_Protocol.Views.MapView"
    x:DataType="viewModels1:MapViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels1="clr-namespace:Isolation_Protocol.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Design.DataContext>
        <viewModels1:MapViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <StyleInclude Source="/Styles/GameHud.axaml" />
    </UserControl.Styles>

    <UserControl.Styles>
        <Style Selector="Border.MapCell">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
        </Style>

        <Style Selector="Border.Wall">
            <Setter Property="Background" Value="#222222" />
            <Setter Property="BorderBrush" Value="#444444" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="Border.Floor">
            <Setter Property="Background" Value="#050505" />
        </Style>

        <Style Selector="Border.Trap">
            <Setter Property="Background" Value="#330000" />
            <Setter Property="BorderBrush" Value="Red" />
        </Style>

        <Style Selector="Border.Exit">
            <Setter Property="Background" Value="#003300" />
            <Setter Property="BorderBrush" Value="#00ff41" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
    </UserControl.Styles>

    <Grid Background="#1a1a1a">
        <Canvas Background="#050505" Name="GameCanvas">

            <!--  Гравець  -->
            <Border
                Background="#00ff41"
                Canvas.Left="{Binding Player.X}"
                Canvas.Top="{Binding Player.Y}"
                CornerRadius="4"
                Height="{Binding Player.Height}"
                Width="{Binding Player.Width}"
                ZIndex="10">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="10"
                        Color="#00ff41"
                        Opacity="0.5" />
                </Border.Effect>
            </Border>
        </Canvas>

        <!--  Інший візуал  -->

        <Border
            BorderThickness="0,2,0,0"
            CornerRadius="8,8,0,0"
            Height="200"
            Margin="10,0,10,0"
            VerticalAlignment="Bottom">
            <Grid ColumnDefinitions="200, *, 300" Margin="10">

                <!--  Герой (Стати)  -->
                <Grid
                    Grid.Column="0"
                    Margin="0,0,10,0"
                    RowDefinitions="*, Auto, Auto">
                    <Border
                        Background="#1a1a1a"
                        BorderBrush="#444444"
                        BorderThickness="2"
                        CornerRadius="4"
                        Grid.Row="0">
                        <TextBlock
                            FontSize="20"
                            Foreground="#444444"
                            HorizontalAlignment="Center"
                            Text="HERO"
                            VerticalAlignment="Center" />
                    </Border>

                    <ProgressBar
                        Classes="HpBar"
                        Grid.Row="1"
                        Value="80" />

                    <ProgressBar
                        Classes="StaminaBar"
                        Grid.Row="2"
                        Value="60" />
                </Grid>

                <!--  Скіли  -->
                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    VerticalAlignment="Bottom">

                    <Grid Classes="SkillPanel">
                        <Border Classes="Ability">
                            <TextBlock Text="1" />
                        </Border>
                        <TextBlock Classes="StaminaCost" Text="50" />
                    </Grid>

                    <Grid Classes="SkillPanel">
                        <Border Classes="Ability">
                            <TextBlock Text="2" />
                        </Border>
                    </Grid>

                    <Grid Classes="SkillPanel">
                        <Border Classes="Ability">
                            <TextBlock Text="3" />
                        </Border>
                    </Grid>

                    <Grid Classes="SkillPanel">
                        <Border Classes="Ability Ultimate">
                            <TextBlock Text="4" />
                        </Border>
                    </Grid>

                </StackPanel>

                <!--  Інвентарь  -->
                <UniformGrid
                    Columns="3"
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    Rows="2">

                    <Border Classes="Slot">
                        <TextBlock Text="1" />
                    </Border>

                    <Border Classes="Slot">
                        <TextBlock Text="2" />
                    </Border>

                    <Border Classes="Slot">
                        <TextBlock Text="3" />
                    </Border>

                    <Border Classes="Slot">
                        <TextBlock Text="4" />
                    </Border>

                    <Border Classes="Slot">
                        <TextBlock Text="5" />
                    </Border>

                    <Border Classes="Slot">
                        <TextBlock Text="6" />
                    </Border>
                </UniformGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>

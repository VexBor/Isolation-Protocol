<UserControl
    x:Class="Isolation_Protocol.Views.InfoView"
    x:DataType="vm:InfoViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:vm="clr-namespace:Isolation_Protocol.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{DynamicResource GlobalBackground}" RowDefinitions="Auto, *, Auto">

        <TextBlock
            Classes="H1"
            Grid.Row="0"
            Margin="60,50,0,0"
            Text="ПРОТОКОЛ: СТАТУС СИСТЕМИ" />

        <Border
            Classes="ContentPanel"
            Grid.Row="1"
            HorizontalAlignment="Left"
            MinWidth="800">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="50,40" Spacing="40">

                    <StackPanel Spacing="10">
                        <TextBlock Classes="H2" Text="[ ОБ'ЄКТ: ОСТРІВ «КЕНОТАФ» ]" />
                        <Separator HorizontalAlignment="Left" Width="200" />
                        <TextBlock Classes="BodyText">
                            <Run FontWeight="Bold" Foreground="#888">РІК: 2097. ОБ'ЄКТ: АРКА-6.</Run>
                            <LineBreak /><LineBreak />
                            Передісторія: Після «Великого Згасання» зв'язок з материком перервався.
                            AEGIS активував протокол «Ізоляція»: периметр заміновано, розгорнуто поле радіомовчання.</TextBlock>
                    </StackPanel>

                    <StackPanel Spacing="10">
                        <TextBlock Classes="H2" Text="[ СТАН ОБ'ЄКТА ]" />
                        <Separator HorizontalAlignment="Left" Width="200" />
                        <TextBlock Classes="BodyText">
                            Природа поглинає базу. AEGIS ліквідує будь-яку ціль без чипа ідентифікації.<LineBreak /><LineBreak />
                            <Run FontWeight="Bold" Foreground="{DynamicResource AccentRed}">⚠️ УВАГА:</Run>
                            Екзокостюм розряджений. Директива: Вижити. Відновити живлення.</TextBlock>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Classes="FooterPanel" Grid.Row="2">
            <StackPanel
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="40">

                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        Classes="SystemText"
                        FontWeight="Bold"
                        Foreground="{DynamicResource AccentRed}"
                        Text="SYSTEM BUILD v0.2.1-ALPHA" />
                    <TextBlock Classes="SystemText" Text="ENGINE: AVALONIA UI (C# / .NET 8)" />
                </StackPanel>

                <Separator Classes="Vertical" />

                <TextBlock
                    Classes="SystemText"
                    Text="LEAD DEVELOPER: ЯКИМ ВАДИМ [ARC-6 / SECTOR-3]"
                    VerticalAlignment="Center" />

                <Button
                    Classes="GhostBtn"
                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OpenMenuCommand}"
                    Content="НАЗАД"
                    Margin="100,0,0,0" />
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
<UserControl
    x:Class="Isolation_Protocol.Views.InfoView"
    x:DataType="vm:InfoViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:vm="clr-namespace:Isolation_Protocol.View"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:services="clr-namespace:Isolation_Protocol.Services">

    <Grid Background="{DynamicResource GlobalBackground}" RowDefinitions="Auto, *, Auto">

        <TextBlock
            Classes="H1"
            Grid.Row="0"
            Margin="60,50,0,0"
            Text="{Binding [Info_Title], Source={x:Static services:Localization.Instance}}" />

        <Border
            Classes="ContentPanel"
            Grid.Row="1"
            HorizontalAlignment="Left"
            MinWidth="800">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="50,40" Spacing="40">

                    <StackPanel Spacing="10">
                        <TextBlock Classes="H2" Text="{Binding [Info_Object_Header], Source={x:Static services:Localization.Instance}}" />
                        <Separator HorizontalAlignment="Left" Width="200" />
                        <TextBlock Classes="BodyText" TextWrapping="Wrap">
                            <Run FontWeight="Bold" Foreground="#888" 
                                 Text="{Binding [Info_Lore_Timestamp], Source={x:Static services:Localization.Instance}}" />
                            <LineBreak /><LineBreak />
                            <Run Text="{Binding [Info_Lore_Text1], Source={x:Static services:Localization.Instance}}" />
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Spacing="10">
                        <TextBlock Classes="H2" Text="{Binding [Info_Status_Header], Source={x:Static services:Localization.Instance}}" />
                        <Separator HorizontalAlignment="Left" Width="200" />
                        <TextBlock Classes="BodyText" TextWrapping="Wrap">
                            <Run Text="{Binding [Info_Status_Text1], Source={x:Static services:Localization.Instance}}" />
                            <LineBreak /><LineBreak />
                            <Run FontWeight="Bold" Foreground="{DynamicResource AccentRed}" 
                                 Text="{Binding [Info_Status_Warning], Source={x:Static services:Localization.Instance}}" />
                            <Run Text="{Binding [Info_Status_Directive], Source={x:Static services:Localization.Instance}}" />
                        </TextBlock>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Classes="FooterPanel" Grid.Row="2">
            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="40">

                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        Classes="SystemText"
                        FontWeight="Bold"
                        Foreground="{DynamicResource AccentRed}"
                        Text="SYSTEM BUILD v0.2.1-ALPHA" />
                    <TextBlock Classes="SystemText" Text="ENGINE: AVALONIA UI (C# / .NET 8)" />
                </StackPanel>

                <Separator Classes="Vertical" />

                <TextBlock
                    Classes="SystemText"
                    Text="DEVELOPER: YAKYM VADYM [ARC-6 / SECTOR-3]"
                    VerticalAlignment="Center" />

                <Button
                    Classes="GhostBtn"
                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OpenMenuCommand}"
                    Content="{Binding [Settings_Back], Source={x:Static services:Localization.Instance}}"
                    Margin="100,0,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
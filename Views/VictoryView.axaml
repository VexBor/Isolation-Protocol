<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:view="clr-namespace:Isolation_Protocol.View"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Isolation_Protocol.Views.VictoryView"
             x:DataType="view:VictoryViewModel">
    <Border Classes="TerminalBorder" Width="550" Height="350" VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel Spacing="20">
            
            <TextBlock Text="{Binding VictoryTitle}" 
                       FontSize="22" 
                       Foreground="#457B9D" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       LetterSpacing="2"/>

            <Border Background="#05FFFFFF" Padding="15" CornerRadius="2" BorderBrush="#2A4736" BorderThickness="1">
                <TextBlock Text="{Binding VictoryLog}" 
                           Classes="TerminalText" 
                           TextWrapping="Wrap"
                           FontFamily="Courier New"
                           LineHeight="20"
                           HorizontalAlignment="Center"/>
            </Border>

            <Button Content="{Binding ExitBtnText}" 
                    Classes="TerminalButton"
                    Command="{Binding $parent[Window].((view:MainWindowViewModel)DataContext).ExitToMenuCommand}"
                    HorizontalAlignment="Center" 
                    Width="200"
                    Margin="0,10,0,0"/>
        </StackPanel>
    </Border>
</UserControl>
